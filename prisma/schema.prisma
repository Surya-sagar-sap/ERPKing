generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  LEARNER
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum InterviewImportance {
  HIGH
  MEDIUM
  LOW
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  avatar         String?
  role           Role     @default(LEARNER)
  // Gamification
  xp             Int      @default(0)
  level          Int      @default(1)
  streak         Int      @default(0)
  lastActiveDate DateTime?
  // Billing (Razorpay)
  plan                   String    @default("free") // "free" | "pro" | "business"
  razorpayCustomerId     String?
  razorpaySubscriptionId String?
  planExpiresAt          DateTime?
  // Relations
  progress       UserProgress[]
  badges         UserBadge[]
  certificates   Certificate[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("users")
}

// ─────────────────────────────────────────────
// CONTENT: MODULE
// ─────────────────────────────────────────────

model Module {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  // Visual
  color       String   @default("#2563EB")
  icon        String?
  order       Int      @default(0)
  // Status
  isPublished Boolean  @default(false)
  // Relations
  lessons      Lesson[]
  certificates Certificate[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("modules")
}

// ─────────────────────────────────────────────
// CONTENT: LESSON
// ─────────────────────────────────────────────

model Lesson {
  id                String          @id @default(cuid())
  moduleId          String
  module            Module          @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title             String
  slug              String
  // The 5-step structure
  story             String          @db.Text  // Step 1: business story
  content           String          @db.Text  // Step 2 & 3: problem + explanation (MDX/markdown)
  keyConceptTitle   String?
  keyConceptBody    String?         @db.Text  // Step 4: SAP link
  // Meta
  order                Int                 @default(0)
  isPublished          Boolean             @default(false)
  estimatedMinutes     Int                 @default(10)
  difficulty           DifficultyLevel     @default(BEGINNER)
  xpReward             Int                 @default(50)
  interviewImportance  InterviewImportance @default(MEDIUM)
  // Relations
  flowchart         Flowchart?
  quiz              Quiz?
  progress          UserProgress[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([moduleId, slug])
  @@map("lessons")
}

// ─────────────────────────────────────────────
// CONTENT: FLOWCHART
// ─────────────────────────────────────────────

model Flowchart {
  id       String          @id @default(cuid())
  lessonId String          @unique
  lesson   Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title    String
  nodes    Json            // React Flow nodes array
  edges    Json            // React Flow edges array
  nodeDetails FlowchartNodeDetail[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("flowcharts")
}

model FlowchartNodeDetail {
  id          String    @id @default(cuid())
  flowchartId String
  flowchart   Flowchart @relation(fields: [flowchartId], references: [id], onDelete: Cascade)
  nodeId      String    // matches the id in React Flow nodes JSON
  title       String
  description String    @db.Text
  tCode       String?   // SAP transaction code e.g. "ME21N"
  tips        String?   @db.Text
  createdAt   DateTime  @default(now())

  @@unique([flowchartId, nodeId])
  @@map("flowchart_node_details")
}

// ─────────────────────────────────────────────
// CONTENT: QUIZ
// ─────────────────────────────────────────────

model Quiz {
  id        String         @id @default(cuid())
  lessonId  String         @unique
  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title     String
  questions QuizQuestion[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("quizzes")
}

model QuizQuestion {
  id          String       @id @default(cuid())
  quizId      String
  quiz        Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question    String       @db.Text
  explanation String?      @db.Text  // shown after answering
  order       Int          @default(0)
  options     QuizOption[]
  createdAt   DateTime     @default(now())

  @@map("quiz_questions")
}

model QuizOption {
  id         String       @id @default(cuid())
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean      @default(false)
  createdAt  DateTime     @default(now())

  @@map("quiz_options")
}

// ─────────────────────────────────────────────
// GAMIFICATION
// ─────────────────────────────────────────────

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  icon        String      // emoji or icon name
  condition   String      // e.g. "complete_fico_module"
  xpReward    Int         @default(100)
  users       UserBadge[]
  createdAt   DateTime    @default(now())

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@map("user_badges")
}

// ─────────────────────────────────────────────
// PROGRESS TRACKING
// ─────────────────────────────────────────────

model UserProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  completedAt DateTime?
  quizScore   Int?      // 0–100
  timeSpent   Int       @default(0) // seconds
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, lessonId])
  @@map("user_progress")
}

// ─────────────────────────────────────────────
// GLOSSARY
// ─────────────────────────────────────────────

model GlossaryTerm {
  id          String   @id @default(cuid())
  term        String   @unique
  definition  String   @db.Text
  moduleSlug  String?  // which module this belongs to
  tCode       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("glossary_terms")
}

// ─────────────────────────────────────────────
// CERTIFICATES
// ─────────────────────────────────────────────

model Certificate {
  id           String   @id @default(cuid())
  userId       String
  moduleId     String
  credentialId String   @unique // e.g. "SAPKING-FICO-2025-A3F7X2"
  issuedAt     DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@map("certificates")
}

// ─────────────────────────────────────────────
// PRICING
// ─────────────────────────────────────────────

model PricingPlan {
  id           String   @id @default(cuid())
  name         String   // "Free", "Pro", "Business"
  slug         String   @unique // "free", "pro", "business"
  monthlyPrice Float    @default(0) // INR, 0 = free
  yearlyPrice  Float    @default(0) // INR/year
  description  String   // one-line tagline
  features     Json     // string[] — bullet point list
  highlighted  Boolean  @default(false) // shows "Most Popular" badge
  ctaText      String   @default("Get started")
  ctaUrl       String   @default("/register")
  isActive     Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  razorpayPlanIdMonthly  String?   // Razorpay Plan ID for monthly billing
  razorpayPlanIdYearly   String?   // Razorpay Plan ID for yearly billing
  currency               String    @default("INR")

  @@map("pricing_plans")
}
