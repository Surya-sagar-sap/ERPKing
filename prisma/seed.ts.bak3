      { id: "node6", type: "default", position: { x: 330, y: 250 }, data: { label: "📊 Monitor (COOIS)" }, style: { background: "#DC2626", color: "#fff", borderRadius: "8px", padding: "10px 16px", width: 140, fontSize: "12px", textAlign: "center" } },
