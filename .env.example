# ─── SUPABASE ───────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── DATABASE ────────────────────────────────────────────────
# For Vercel (serverless) use the TRANSACTION POOLER on port 6543:
# supabase.com → your project → Settings → Database → Connection Pooling → Transaction mode
# Add ?pgbouncer=true to the end
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

# For migrations/seeding, use the DIRECT connection on port 5432:
# supabase.com → your project → Settings → Database → Connection string (URI)
DIRECT_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# ─── ADMIN ──────────────────────────────────────────────────
# Change this to something secret before going live
ADMIN_SECRET=change-me-to-something-secret

# ─── RAZORPAY ───────────────────────────────────────────────
# Get these from: Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# Razorpay Dashboard → Settings → Webhooks → (your webhook) → Secret
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ─── RATE LIMITING (optional) ───────────────────────────────
# Create a free Redis DB at console.upstash.com → REST API section.
# If unset, rate limiting is silently disabled (app still works).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
